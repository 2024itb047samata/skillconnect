{
  "buildCommand": "pnpm --filter @workspace/skillconnect run build",
  "outputDirectory": "artifacts/skillconnect/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/",
    "PORT": "3000"
  }
}
